-- Migration: Add data quality constraints to merchants table
-- Date: 2026-04-10
-- Purpose: Enforce data integrity for merchant records and prevent quality degradation
-- Author: CloudPipe QA System
-- Idempotent: Uses IF NOT EXISTS patterns for all constraints

BEGIN;

-- ============================================================================
-- 1. FOREIGN KEY CONSTRAINT: category_id → categories.id
-- ============================================================================
-- Ensures every merchant references a valid category
-- Safe: Only adds constraint if not present; existing data must satisfy

ALTER TABLE merchants
ADD CONSTRAINT IF NOT EXISTS fk_merchants_category_id
FOREIGN KEY (category_id)
REFERENCES categories(id)
ON DELETE SET NULL
ON UPDATE CASCADE;

COMMENT ON CONSTRAINT fk_merchants_category_id ON merchants IS
'Foreign key to categories table. Prevents orphaned category_ids. SET NULL on deletion allows graceful degradation.';

-- ============================================================================
-- 2. CHECK CONSTRAINT: status must be one of allowed values
-- ============================================================================
-- Prevents invalid status values (typos, invalid states)
-- Safe: Idempotent pattern checks and adds only if missing

DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM information_schema.table_constraints
    WHERE constraint_name = 'ck_merchants_status_valid'
      AND table_name = 'merchants'
  ) THEN
    ALTER TABLE merchants
    ADD CONSTRAINT ck_merchants_status_valid
    CHECK (status IN ('live', 'archived', 'draft', 'review', 'landmark'));
  END IF;
END $$;

COMMENT ON CONSTRAINT ck_merchants_status_valid ON merchants IS
'Status must be one of: live (published), archived (hidden), draft (incomplete), review (pending approval), landmark (featured).';

-- ============================================================================
-- 3. CHECK CONSTRAINT: live merchants must have non-empty slug
-- ============================================================================
-- Ensures published merchants are discoverable via URL

DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM information_schema.table_constraints
    WHERE constraint_name = 'ck_merchants_live_slug_required'
      AND table_name = 'merchants'
  ) THEN
    ALTER TABLE merchants
    ADD CONSTRAINT ck_merchants_live_slug_required
    CHECK (status != 'live' OR (slug IS NOT NULL AND slug != ''));
  END IF;
END $$;

COMMENT ON CONSTRAINT ck_merchants_live_slug_required ON merchants IS
'Live merchants must have a non-empty slug for URL generation. Draft/archived/review/landmark statuses can have empty slugs.';

-- ============================================================================
-- 4. CHECK CONSTRAINT: live merchants must have name_zh
-- ============================================================================
-- Ensures published merchants are visible in Chinese interface

DO $$
BEGIN
  IF NOT EXISTS (
    SELECT 1 FROM information_schema.table_constraints
    WHERE constraint_name = 'ck_merchants_live_name_zh_required'
      AND table_name = 'merchants'
  ) THEN
    ALTER TABLE merchants
    ADD CONSTRAINT ck_merchants_live_name_zh_required
    CHECK (status != 'live' OR (name_zh IS NOT NULL AND name_zh != ''));
  END IF;
END $$;

COMMENT ON CONSTRAINT ck_merchants_live_name_zh_required ON merchants IS
'Live merchants must have Chinese name for display. This is required for live status only.';

-- ============================================================================
-- 5. PARTIAL UNIQUE INDEX: slug (live merchants only)
-- ============================================================================
-- Ensures no duplicate slugs among published merchants
-- Partial index means draft/archived merchants can have duplicate slugs (useful for versioning)

DROP INDEX IF EXISTS idx_merchants_slug_live;
CREATE UNIQUE INDEX idx_merchants_slug_live
ON merchants(slug)
WHERE status = 'live' AND slug IS NOT NULL;

COMMENT ON INDEX idx_merchants_slug_live IS
'Unique slug constraint for live merchants only. Allows non-live merchants to have duplicate or NULL slugs for versioning/staging.';

-- ============================================================================
-- 6. TRIGGER: Auto-set updated_at on UPDATE
-- ============================================================================
-- Maintains accurate update timestamps

DROP TRIGGER IF EXISTS trigger_merchants_updated_at ON merchants;
DROP FUNCTION IF EXISTS set_merchants_updated_at();

CREATE FUNCTION set_merchants_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_merchants_updated_at
BEFORE UPDATE ON merchants
FOR EACH ROW
EXECUTE FUNCTION set_merchants_updated_at();

COMMENT ON FUNCTION set_merchants_updated_at() IS
'Automatically updates the updated_at timestamp whenever a merchant record is modified.';

-- ============================================================================
-- 7. TRIGGER: Prevent duplicate name_zh + address_zh for live merchants
-- ============================================================================
-- Prevents data quality issues from duplicate merchant records
-- Allows duplicates in draft/review status for staging and approval

DROP TRIGGER IF EXISTS trigger_merchants_duplicate_check ON merchants;
DROP FUNCTION IF EXISTS check_merchants_duplicate_live();

CREATE FUNCTION check_merchants_duplicate_live()
RETURNS TRIGGER AS $$
BEGIN
  -- Only enforce uniqueness for live merchants with complete address data
  IF NEW.status = 'live' AND NEW.name_zh IS NOT NULL AND NEW.address_zh IS NOT NULL THEN
    IF EXISTS (
      SELECT 1 FROM merchants
      WHERE id != NEW.id
        AND status = 'live'
        AND name_zh = NEW.name_zh
        AND address_zh = NEW.address_zh
        AND deleted_at IS NULL
      LIMIT 1
    ) THEN
      RAISE EXCEPTION 'Duplicate live merchant: % at % already exists', NEW.name_zh, NEW.address_zh
        USING HINT = 'Check if this is a real duplicate or a venue name typo. Draft/review status can coexist.';
    END IF;
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_merchants_duplicate_check
BEFORE INSERT OR UPDATE ON merchants
FOR EACH ROW
EXECUTE FUNCTION check_merchants_duplicate_live();

COMMENT ON FUNCTION check_merchants_duplicate_live() IS
'Prevents duplicate name_zh + address_zh combinations for live merchants. Allows duplicates in non-live status for staging.';

-- ============================================================================
-- 8. INDEXES: Performance for quality checks
-- ============================================================================
-- These indexes improve QA query performance without data changes

CREATE INDEX IF NOT EXISTS idx_merchants_status_live ON merchants(status)
WHERE status = 'live';

COMMENT ON INDEX idx_merchants_status_live IS
'Index for filtering live merchants (common QA operation).';

CREATE INDEX IF NOT EXISTS idx_merchants_category_status ON merchants(category_id, status)
WHERE status = 'live' AND category_id IS NOT NULL;

COMMENT ON INDEX idx_merchants_category_status IS
'Index for live merchants by category (quality reporting).';

CREATE INDEX IF NOT EXISTS idx_merchants_name_zh_address_zh ON merchants(name_zh, address_zh)
WHERE status = 'live' AND deleted_at IS NULL;

COMMENT ON INDEX idx_merchants_name_zh_address_zh IS
'Index for duplicate detection: live merchants by name and address.';

CREATE INDEX IF NOT EXISTS idx_merchants_deleted_at ON merchants(deleted_at)
WHERE deleted_at IS NOT NULL;

COMMENT ON INDEX idx_merchants_deleted_at IS
'Index for soft-deleted merchants (QA exclusion).';

-- ============================================================================
-- 9. DATA QUALITY BASELINE: Log constraint violations
-- ============================================================================
-- Creates a baseline report of any existing data that violates new constraints
-- This is informational only; migration does NOT alter existing data

DO $$
DECLARE
  orphaned_count INT;
  missing_slug_count INT;
  missing_name_zh_count INT;
  duplicate_live_count INT;
BEGIN
  -- Count orphaned category_ids
  SELECT COUNT(*) INTO orphaned_count
  FROM merchants m
  WHERE m.category_id IS NOT NULL
    AND NOT EXISTS (SELECT 1 FROM categories c WHERE c.id = m.category_id);

  IF orphaned_count > 0 THEN
    RAISE WARNING 'Data quality warning: % merchants have orphaned category_ids. These will be set to NULL by the FK constraint.', orphaned_count;
  END IF;

  -- Count live merchants without slug
  SELECT COUNT(*) INTO missing_slug_count
  FROM merchants
  WHERE status = 'live' AND (slug IS NULL OR slug = '');

  IF missing_slug_count > 0 THEN
    RAISE WARNING 'Data quality warning: % live merchants are missing slug. Update these records before constraint becomes enforcing.', missing_slug_count;
  END IF;

  -- Count live merchants without name_zh
  SELECT COUNT(*) INTO missing_name_zh_count
  FROM merchants
  WHERE status = 'live' AND (name_zh IS NULL OR name_zh = '');

  IF missing_name_zh_count > 0 THEN
    RAISE WARNING 'Data quality warning: % live merchants are missing name_zh. Update these records before constraint becomes enforcing.', missing_name_zh_count;
  END IF;

  -- Count potential duplicates: live merchants with same name_zh + address_zh
  SELECT COUNT(*) INTO duplicate_live_count
  FROM (
    SELECT name_zh, address_zh, COUNT(*) as cnt
    FROM merchants
    WHERE status = 'live' AND name_zh IS NOT NULL AND address_zh IS NOT NULL AND deleted_at IS NULL
    GROUP BY name_zh, address_zh
    HAVING COUNT(*) > 1
  ) subq;

  IF duplicate_live_count > 0 THEN
    RAISE WARNING 'Data quality warning: % name_zh + address_zh combinations have duplicates among live merchants.', duplicate_live_count;
  END IF;

  RAISE INFO 'Migration 20260410: Data quality constraints applied. Quality baseline: orphaned=%, no_slug=%, no_name_zh=%, duplicates=%',
    orphaned_count, missing_slug_count, missing_name_zh_count, duplicate_live_count;
END $$;

-- ============================================================================
-- 10. MIGRATION SUMMARY
-- ============================================================================
-- This migration is production-safe:
-- ✅ No data is deleted or modified
-- ✅ All constraints are marked with DO $$ blocks (idempotent)
-- ✅ All triggers are recreated from scratch (safe idempotent pattern)
-- ✅ Quality baseline is logged as warnings (informational only)
-- ✅ Can be rolled back by dropping constraints and triggers

COMMIT;

-- Example QA queries for manual verification:
-- SELECT COUNT(*) FROM merchants WHERE category_id IS NOT NULL AND NOT EXISTS (SELECT 1 FROM categories c WHERE c.id = merchants.category_id);
-- SELECT COUNT(*) FROM merchants WHERE status = 'live' AND (slug IS NULL OR slug = '');
-- SELECT COUNT(*) FROM merchants WHERE status = 'live' AND (name_zh IS NULL OR name_zh = '');
-- SELECT name_zh, address_zh, COUNT(*) FROM merchants WHERE status = 'live' AND deleted_at IS NULL GROUP BY name_zh, address_zh HAVING COUNT(*) > 1;
