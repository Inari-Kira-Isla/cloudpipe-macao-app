# CloudPipe Google Sheets ↔ Supabase 同步配置模板
#
# 复制此文件为 .env.local 或 .env，然后填写实际值
# 或者设置以下环境变量到 shell 配置（~/.bashrc, ~/.zshrc）

# ============================================================
# Supabase 配置（通常已在 .env.local 中）
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://yitmabzsxfgbchhhjjef.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# ============================================================
# Google Sheets 配置
# ============================================================

# Google Sheet ID（从 Sheet URL 中获取）
# URL: https://docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# 示例：1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
GOOGLE_SHEET_ID=YOUR_SHEET_ID_HERE

# Google 服务账户凭证 JSON 文件路径
# 获取方式：
# 1. Google Cloud Console > Service Accounts
# 2. 创建服务账户
# 3. 创建 JSON 密钥
# 4. 保存到 ~/.config/cloudpipe/google_creds.json
GOOGLE_CREDENTIALS_JSON=~/.config/cloudpipe/google_creds.json

# ============================================================
# 可选配置
# ============================================================

# Python 脚本日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 每次同步的最大行数（防止超时）
MAX_ROWS_PER_SYNC=1000

# 爬虫访问数据查询天数
CRAWLER_VISITS_DAYS=30

# Slack 通知（可选）
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 邮件通知（可选）
# EMAIL_NOTIFY=true
# EMAIL_RECIPIENT=your@email.com
# EMAIL_SENDER=noreply@cloudpipe.com

# ============================================================
# LaunchAgent 配置（自动生成，不需手动修改）
# ============================================================
# LAUNCHAGENT_INTERVAL=3600  # 每小时运行（秒）
